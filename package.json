{
  "name": "mcp-manager",
  "version": "1.0.0",
  "description": "TUI for managing MCP tool permissions in Claude Code (~/.claude.json)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "bin": {
    "mcp-manager": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zed13/mcp-manager.git"
  },
  "keywords": ["mcp", "claude", "tui", "cli"],
  "author": "Denis Danilchuk",
  "engines": {
    "node": ">=22"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zed13/mcp-manager/issues"
  },
  "homepage": "https://github.com/zed13/mcp-manager#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
